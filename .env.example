# SW_SOURCING_DB_PATH=sw_sourcing.db
# SW_SOURCING_BUG_REPORTS_DIR=bug_reports
# SW_SOURCING_LOCK_PATH=sw_sourcing.scan.lock
# SW_SOURCING_LOG_PATH=sw_sourcing.log
# FACEBOOK_INBOX_DIR=facebook_inbox
